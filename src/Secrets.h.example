#pragma once
// ============================================================
//  Secrets.h.example  –  TEMPLATE for src/Secrets.h
//
//  This placeholder file IS tracked by git.  The real Secrets.h is
//  NOT (see .gitignore).  To set up a device:
//
//      cp src/Secrets.h.example src/Secrets.h
//      # then edit src/Secrets.h with this device's real values
//
//  Config.h #includes "Secrets.h" at its end, so the names below are
//  visible everywhere they were before the split.  Do not #include
//  this file directly — it relies on the MQTT_TLS / MQTT_TLS_MUTUAL
//  macros that Config.h defines first.
// ============================================================

// ── WiFi (station mode) ──────────────────────────────────────
//  Leave WIFI_SSID empty ("") to run as a standalone access point.
[[maybe_unused]] constexpr char WIFI_SSID[]     = "";
[[maybe_unused]] constexpr char WIFI_PASSWORD[] = "";

// ── Standalone access-point password (8–63 chars, WPA2) ──────
//  Left at this default → a random per-device password is generated
//  at first boot and shown on the LCD.  Set your own to override.
[[maybe_unused]] constexpr char AP_PASSWORD[]   = "m5stack-config";

// ── Dashboard / Web API login ────────────────────────────────
//  Empty user ("") disables auth.  CHANGE these before deploying —
//  the shipped user / password pair is refused at boot.
[[maybe_unused]] constexpr char WEB_AUTH_USER[] = "CHANGE_ME";
[[maybe_unused]] constexpr char WEB_AUTH_PASS[] = "CHANGE_ME";

// ── MQTT broker login (empty = anonymous / cert-only) ────────
[[maybe_unused]] constexpr char MQTT_USER[] = "";
[[maybe_unused]] constexpr char MQTT_PASS[] = "";

// ── Router → Pi orchestrator bearer token ("" = none) ────────
[[maybe_unused]] constexpr char ROUTER_BEARER[] = "";

// ── Claude direct-API key ("" = plugin inert) ────────────────
[[maybe_unused]] constexpr char CLAUDE_API_KEY[] = "";

// ── Inbound webhook API key ("" = Basic Auth fallback) ───────
//  When non-empty, POST /api/alerts/inject is authenticated by an
//  X-API-Key header matching this value — no browser credentials
//  needed, making it usable by any external system or automation.
//  When empty, the endpoint falls back to standard HTTP Basic Auth
//  (WEB_AUTH_USER / WEB_AUTH_PASS).  Pick a long random string and
//  treat it like a password.
[[maybe_unused]] constexpr char WEBHOOK_INJECT_API_KEY[] = "";

// ── MQTT mutual-TLS client cert + private key ────────────────
//  Only compiled in when MQTT_TLS && MQTT_TLS_MUTUAL (Config.h).
#if MQTT_TLS && MQTT_TLS_MUTUAL
[[maybe_unused]] static const char MQTT_CLIENT_CERT[] = R"EOF(
-----BEGIN CERTIFICATE-----
PASTE THIS DEVICE'S CLIENT CERTIFICATE (xxxx-certificate.pem.crt) HERE
-----END CERTIFICATE-----
)EOF";

[[maybe_unused]] static const char MQTT_CLIENT_KEY[] = R"EOF(
-----BEGIN RSA PRIVATE KEY-----
PASTE THIS DEVICE'S PRIVATE KEY (xxxx-private.pem.key) HERE
-----END RSA PRIVATE KEY-----
)EOF";
#endif  // MQTT_TLS && MQTT_TLS_MUTUAL
